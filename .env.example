# MongoDB
MONGODB_URI=example_url
# JWT
JWT_SECRET=example_url
AUTH_COOKIE_NAME=example_url
AUTH_COOKIE_SAME_SITE=example_url
# For cross-site frontend+API domains in production, set AUTH_COOKIE_SAME_SITE=none
# and provide a shared cookie domain if needed (for example .devverify.online).
AUTH_COOKIE_DOMAIN=example_url

# Upstash Redis (Optional - API works without it)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Resend Email Service
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=no-reply@devverify.online
EMAIL_FROM_NAME=DevVerify

# Groq AI
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# OnlineCompiler
ONLINECOMPILER_API_KEY=your_onlinecompiler_api_key_here
ONLINECOMPILER_BASE_URL=example_url

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
API_BASE_URL=http://localhost:5001
GITHUB_CALLBACK_URL=http://localhost:5001/api/auth/github/callback
